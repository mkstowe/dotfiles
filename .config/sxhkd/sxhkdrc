# Launch programs
super + Return
	kitty

super + shift + Return
	kitty -e ranger

super + d
	rofi -show run

super + shift + f
	firefox

super + shift + d
	lightcord

super + shift + s
	spotify

super + shift + j
	jetbrains-toolbox

super + shift + u
	unityhub

super + shift + t 
	steam


# Audio
XF86AudioMute
    pactl set-sink-mute 0 toggle

{XF86AudioLowerVolume,XF86AudioRaiseVolume}
    pactl set-sink-mute 0 false ; pactl set-sink-volume 0 {-,+}5%


# Power
super + shift + Escape
	systemctl poweroff

super + ctrl + Escape
	systemctl reboot

# Logout
super + Escape
	kill -9 -1


# Reload sxhkd
super + shift + BackSpace
	pkill -USR1 -x sxhkd; notify-send 'sxhkd' 'Reloaded config'


# Screenshot region
super + shift + p
	import ~/Pictures/screenshots/$(date +'%Y-%m-%d-%H-%M-%S').png

# Screenshot whole display
super + p
	import -window root ~/Pictures/screenshots/$(date +'%Y-%m-%d-%H-%M-%S').png


#############
##  BSPWM  ##
#############

# Restart
super + shift + r
	pkill panel; ~/.config/bspwm/bspwmrc

# Close focused window
super + q
	bspc node -c

## send the window in the given direction
super + {_,shift + }{Left,Down,Up,Right}
	bspc node -{f,s} {west,south,north,east}

## focus or send to the given desktop
super + {_,shift + }{1-9,0}
	bspc {desktop -f,node -d} '^{1-9,10}'
	
## jump to another workspace
super + {1-9,0}
	bspc desktop --focus^{1-9,10}

# spit horizontal & split vertical, like in i3-gaps :D
#super + {h,v}
	#bspc node -p {east,south}
	
# Resize windows
super + r : {h,j,k,l}
    STEP=20; SELECTION={1,2,3,4}; \
    bspc node -z $(echo "left -$STEP 0,bottom 0 $STEP,top 0 -$STEP,right $STEP 0" | cut -d',' -f$SELECTION) || \
    bspc node -z $(echo "right -$STEP 0,top 0 $STEP,bottom 0 -$STEP,left $STEP 0" | cut -d',' -f$SELECTION)

super + r : {Left,Down,Up,Right}
    STEP=20; SELECTION={1,2,3,4}; \
    bspc node -z $(echo "left -$STEP 0,bottom 0 $STEP,top 0 -$STEP,right $STEP 0" | cut -d',' -f$SELECTION) || \
    bspc node -z $(echo "right -$STEP 0,top 0 $STEP,bottom 0 -$STEP,left $STEP 0" | cut -d',' -f$SELECTION)

# Rotate windows
super + {bracketleft,bracketright}
	bspc node @/ -C {backward,forward}
