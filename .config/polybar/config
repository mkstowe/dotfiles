[bar/base]
bottom = false
height = 25
offset-y = 1%
radius = 0
fixed-center = true

foreground = #282a36
background = #bd93f9

line-size = 2

border-size = 0

padding-left = 0
padding-right = 0
module-margin-left = 4%
module-margin-right = 0

font-0 = Courier Prime:fontformat=truetype:size=10;2
font-1 = Font Awesome 5 Free Solid:fontformat=truetype;3
font-2 = Font Awesome 5 Brands Regular:fontformat=truetype;3

override-redirect = true
wm-restack = i3


[bar/volume]
inherit = bar/base
width = 4%
offset-x = 1.5%

modules-center = volume


[bar/controls]
inherit = bar/base
width = 6%
offset-x = 6%

modules-center = prev toggle next


[bar/spotify]
inherit = bar/base
width = 15%
offset-x = 12.5%

modules-center = spotify


[bar/wm]
inherit = bar/base
width = 20%
offset-x = 40%
fixed-center = true

background = #00000000

modules-center = i3


[bar/date]
inherit = bar/base
width = 10%
offset-x = 88.5%

override-redirect = true
modules-center = date


[module/i3]
type = internal/i3

;label-unfocused-background = #20282c
label-unfocused-foreground = #f8f8f2

label-mode = %mode%
label-mode-padding = 2

label-focused = %name%
label-focused-foreground = #bd93f9
;label-focused-background = #20282c
label-focused-underline = #bd93f9
label-focused-padding = 2

label-unfocused = %index%
label-unfocused-padding = 2

label-visible = %index%
label-visible-padding = 4

label-urgent = %index%
label-urgent-foreground = #ff5555
label-urgent-background = #282a36
label-urgent-padding = 2


[module/volume]
type = internal/pulseaudio

use-ui-max = false

format-volume = <ramp-volume>  <label-volume>
label-volume = %percentage%%
label-muted = ’Ü® muted

;format-foreground = #20282c
;label-foreground = #20282c
;label-volume-foreground = #20282c
;label-muted-foreground = #20282c
;ramp-volume-foreground = #20282c

ramp-volume-0 = ’Ć”
ramp-volume-1 = ’Ć¦
ramp-volume-2 = ’Ć©


[module/date]
type = internal/date
interval = 5

date =
date-alt = "%d/%m/%Y"

time = "%a %b %d, %I:%M %p "

time-alt = %H:%M

;format-foreground = #20282c

label = %date% %time%


[settings]
screenchange-reload = true


[module/xwindow]
type = internal/xwindow
label = %title:0:30:...%
label-padding = 10
label-foreground = #20282c


[module/spotify]
type = custom/script
exec = $HOME/.config/polybar/scripts/song 2>/dev/null || echo "[-]"

format = "<label>"
interval = 1
;format-foreground = #20282c


[module/prev]
type = custom/script
exec = echo "%{T5}’üō%{T-}" &

format = "<label>"
;format-foreground = #20282c

interval = 600
tail = true
 
click-left = playerctl --player=spotify previous &


[module/toggle]
type = custom/script
exec = [[ "$(playerctl -p spotify status 2>/dev/null)" == "Playing" ]] && echo "’üī" || echo "’üŗ"

interval = 0.1
format = "<label>"
;format-foreground = #20282c
tail = true

click-left = playerctl --player=spotify play-pause &


[module/next]
type = custom/script
exec = echo "%{T5}’üö%{T-}" &

format = "<label>"
;format-foreground = #20282c

interval = 600
tail = true

click-left = playerctl --player=spotify next &
