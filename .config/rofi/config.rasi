configuration {
	font: "Courier Prime 24";
	lines: 4;
	eh: 1;
	width: 100;
	padding: 650;
	opacity: "85";
	bw: 0;
	line-padding: 20;
	hide-scrollbar: true;

	color-normal: "#1d2329, #DCBDC0, #1d2329, #1d2329, #e3dfdb";
	color-urgent: "#1d2329, #DCBDC0, #1d2329, #1d2329, #e3dfdb";
	color-active: "#1d2329, #DCBDC0, #1d2329, #1d2329, #e3dfdb";
	color-window: "#1d2329, #1d2329, #DCBDC0";
}
