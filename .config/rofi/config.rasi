configuration {
	font: "Courier Prime 24";
	lines: 4;
	eh: 1;
	width: 100;
	padding: 650;
	opacity: "85";
	bw: 0;
	line-padding: 20;
	hide-scrollbar: true;

	color-normal: "#282a36, #6272a4, #282a36, #282a36, #f8f8f2";
	color-urgent: "#282a36, #6272a4, #282a36, #282a36, #f8f8f2";
	color-active: "#282a36, #6272a4, #282a36, #282a36, #f8f8f2";
	color-window: "#282a36, #282a36, #6272a4";
}
