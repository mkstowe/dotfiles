{
  "meta": {
    "configVersion": 1,
    "schema": "quickshell.theme.tokens"
  },

  "spacing": {
    "xs": 4,
    "sm": 8,
    "md": 12,
    "lg": 16,
    "xl": 24
  },

  "radius": {
    "sm": 8,
    "md": 12,
    "lg": 16,
    "xl": 20
  },

  "typography": {
    "fontFamily": "Caskaydia Cove Nerd Font",
    "fontSize": 15,
    "fontWeight": 400,
    "monoFamily": "JetBrains Mono"
  },

  "elevation": {
    "shadowBlur": 24,
    "shadowOffsetY": 10,
    "shadowOpacity": 0.35
  },

  "colors": {
    "dark": "palette.dark",
    "light": "palette.light",
    "muted": "palette.muted",
    "primary": "palette.primary",
    "secondary": "palette.secondary",
    "accent": "palette.accent",
    "success": "palette.success",
    "danger": "palette.danger",
    "warning": "palette.warning",
    "info": "palette.info"
  }
}